# The rave-of-agents reads all its secrets from a single machine-wide file:
#   ~/.rave-of-agents/.env   (override with RAVE_OF_AGENTS_ENV_FILE)
# so the server works no matter which directory it's launched from. A .env in
# the cwd or an exported env var still works and takes precedence. Copy the keys
# below into ~/.rave-of-agents/.env and fill them in. See app/env.ts.

# --- Supabase: durable session storage (app/persistence.ts) ---
# From the Supabase dashboard (Project Settings → API) or, in this workspace,
# via the Soda Straw `supabase` straw (get_project_url / get_publishable_keys).
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx

# --- Linear project board via the Soda Straw gateway (app/linear-gateway.ts) ---
SODA_STRAW_GATEWAY_URL=https://<workspace>.straw.../mcp
SODA_STRAW_API_KEY=ssa_...          # scoped agent key (straw: linear, full access)
LINEAR_TEAM_ID=<team uuid>          # the team projects/issues live under
SODA_STRAW_LINEAR_STRAW=linear      # straw name (optional, default "linear")
